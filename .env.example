PORT=3000

# Gemini live
GEMINI_API_KEY=
STT_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_CONNECT_MAX_ATTEMPTS=4
GEMINI_CONNECT_RETRY_DELAY_MS=500

# Proxy
PROXY_SCHEME=
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=
PROXY_CONNECT_TIMEOUT_MS=6000

# Yandex runtimes
YANDEX_API_KEY=
YANDEX_IAM_TOKEN=
YANDEX_FOLDER_ID=
YANDEX_MODEL_ID=yandexgpt-lite/latest
YANDEX_REALTIME_URL=wss://ai.api.cloud.yandex.net/v1/realtime/openai
YANDEX_BATYUSHKA_VECTOR_STORE_ID=

# Browser runtime
BROWSER_RESOLVER_MODEL=gemini-3-flash-preview
BROWSER_PROXY_MODE=direct
BROWSER_ORIGIN_PROBE_TIMEOUT_MS=2500
BROWSER_IDLE_TIMEOUT_MS=30000
BROWSER_SESSION_TTL_MS=600000
SITE_RESOLUTION_TIMEOUT_MS=6000

# Runtime data
VOICE_SESSION_TTL_MS=120000
RUNTIME_DATA_DIR=
APP_CONFIG_PATH=
CONVERSATIONS_DIR=
KNOWLEDGE_DIR=
RUNTIME_LOG_PATH=
